Table "event_guests" [note: 'concept: Person (secondary, stitch_key: guest__email) + Interaction (primary, links: Person → Event(meetup))'] {
    "api_id" string
    "guest__api_id" string
    "guest__approval_status" string
    "guest__created_at" timestamp('UTC')
    "guest__invited_at" timestamp('UTC')
    "guest__user_api_id" string
    "guest__id" string
    "guest__user_id" string
    "guest__user_email" string
    "guest__email" string [note: 'stitch_key']
    "guest__check_in_qr_code" string
    "_events_api_id" string
    "_dlt_load_id" !string
    "_dlt_id" !string
    "guest__registered_at" timestamp('UTC')
    "guest__user_name" string
    "guest__user_first_name" string
    "guest__user_last_name" string
    "guest__name" string
    "guest__event_ticket__amount" int64
    "guest__event_ticket__amount_discount" int64
    "guest__event_ticket__amount_tax" int64
    "guest__event_ticket__id" string
    "guest__event_ticket__api_id" string
    "guest__event_ticket__event_ticket_type_id" string
    "guest__event_ticket__is_captured" boolean
    "guest__event_ticket__name" string
    "guest__phone_number" string
    "guest__custom_source" string
    "guest__checked_in_at" timestamp('UTC')
    "guest__event_ticket__checked_in_at" timestamp('UTC')
    "guest__event_ticket__currency" string
    "guest__joined_at" timestamp('UTC')
    "event_api_id" string
}

Table "event_guests__guest__event_tickets" [note: 'excluded: nested ticket detail, derivable from event_guests'] {
    "amount" int64
    "amount_discount" int64
    "amount_tax" int64
    "id" string
    "api_id" string
    "event_ticket_type_id" string
    "is_captured" boolean
    "name" string
    "_dlt_parent_id" !string
    "_dlt_list_idx" !int64
    "_dlt_id" !string
    "checked_in_at" timestamp('UTC')
    "currency" string
}

Table "event_guests__guest__registration_answers" [note: 'excluded: registration answers, not a core business entity'] {
    "label" string
    "value" boolean
    "answer" boolean
    "question_id" string
    "question_type" string
    "_dlt_parent_id" !string
    "_dlt_list_idx" !int64
    "_dlt_id" !string
    "value__company" string
    "value__job_title" string
    "answer__v_text" string
    "answer_company" string
    "answer_job_title" string
    "value__v_text" string
}

Table "events" [note: 'concept: Event | role: primary | subtype: meetup'] {
    "api_id" string
    "event__id" string
    "event__calendar_id" string
    "event__user_id" string
    "event__created_at" timestamp('UTC')
    "event__cover_url" string
    "event__name" string
    "event__description" string
    "event__description_md" string
    "event__start_at" timestamp('UTC')
    "event__duration_interval" string
    "event__end_at" timestamp('UTC')
    "event__geo_address_json__address" string
    "event__geo_address_json__city" string
    "event__geo_address_json__region" string
    "event__geo_address_json__city_state" string
    "event__geo_address_json__full_address" string
    "event__geo_address_json__google_maps_place_id" string
    "event__geo_address_json__description" string
    "event__geo_latitude" string
    "event__geo_longitude" string
    "event__url" string
    "event__timezone" string
    "event__visibility" string
    "event__api_id" string
    "event__calendar_api_id" string
    "event__user_api_id" string
    "_dlt_load_id" !string
    "_dlt_id" !string
    "event__meeting_url" string
    "event__zoom_meeting_url" string
    "event__geo_address_json__country" string
    "event__geo_address_json__apple_maps_place_id" string
    "event__feedback_email__enabled" boolean
    "event__feedback_email__delay" string
}

Table "events__event__registration_questions" [note: 'excluded: event metadata, not a business entity'] {
    "id" string
    "label" string
    "required" boolean
    "question_type" string
    "_dlt_parent_id" !string
    "_dlt_list_idx" !int64
    "_dlt_id" !string
    "job_title_label" string
    "collect_job_title" boolean
}
