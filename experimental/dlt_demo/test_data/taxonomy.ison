{
  "_version": "1.0",
  "Person": {
    "description": "Any individual — an AC contact or a Luma event guest",
    "use_cases": ["track people across education sign-ups and meetup attendance", "unify identity across systems"],
    "references": ["contact", "guest", "attendee"],
    "tables": [
      {"table": "contacts", "source_pipeline": "active_campaigns", "role": "primary"},
      {"table": "event_guests", "source_pipeline": "luma_events_data", "role": "secondary"}
    ],
    "stitch_key": "email",
    "assumptions": ["AC contacts.email and Luma event_guests.guest__email used as stitch key"]
  },
  "Event": {
    "description": "Any interaction type — a Luma meetup, an AC education program (tag), or an AC mailing list",
    "use_cases": ["classify all company interactions", "report on event types and reach"],
    "references": ["meetup", "workshop", "course", "tag", "list", "campaign"],
    "tables": [
      {"table": "events", "source_pipeline": "luma_events_data", "role": "primary"},
      {"table": "tags", "source_pipeline": "active_campaigns", "role": "secondary"},
      {"table": "lists", "source_pipeline": "active_campaigns", "role": "secondary"}
    ],
    "stitch_key": null,
    "assumptions": [
      "AC tags and lists both treated as Event definitions — tags = education programs, lists = campaign/engagement categories",
      "6 AC tags excluded as non-events: source1, Title, Also_Marketing_Permission, unsubscribed from education, test name field variables, 2024"
    ]
  },
  "Interaction": {
    "description": "A person's participation in an Event — Luma guest registration or AC tag/list assignment",
    "use_cases": ["track who attended which meetup", "track who enrolled in which education program", "unified interaction history per person"],
    "references": ["event_guest", "contact_tag", "contact_list", "enrollment", "attendance", "sign-up"],
    "tables": [
      {"table": "event_guests", "source_pipeline": "luma_events_data", "role": "primary"},
      {"table": "contact_tags", "source_pipeline": "active_campaigns", "role": "secondary"},
      {"table": "contact_lists", "source_pipeline": "active_campaigns", "role": "secondary"}
    ],
    "stitch_key": null,
    "assumptions": [
      "event_guests also contributes to Person — dual role table",
      "contact_lists included as interactions since lists are treated as Events"
    ]
  },
  "_excluded": [
    {"table": "event_guests__guest__event_tickets", "source_pipeline": "luma_events_data", "reason": "nested ticket detail, derivable from event_guests"},
    {"table": "event_guests__guest__registration_answers", "source_pipeline": "luma_events_data", "reason": "registration answers, not a core business entity"},
    {"table": "events__event__registration_questions", "source_pipeline": "luma_events_data", "reason": "event metadata, not a business entity"},
    {"table": "tags (6 rows)", "source_pipeline": "active_campaigns", "reason": "non-event tags excluded by user: source1, Title, Also_Marketing_Permission, unsubscribed from education, test name field variables, 2024"}
  ]
}
