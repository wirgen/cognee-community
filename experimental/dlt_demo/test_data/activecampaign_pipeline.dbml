Table "contacts" [note: 'concept: Person | role: primary | stitch_key: email'] {
    "cdate" timestamp
    "email" text [note: 'stitch_key']
    "phone" text
    "first_name" text
    "last_name" text
    "orgid" text
    "orgname" text
    "segmentio_id" text
    "bounced_hard" text
    "bounced_soft" text
    "ip" text
    "hash" text
    "email_local" text
    "email_domain" text
    "sentcnt" text
    "gravatar" text
    "deleted" text
    "anonymized" text
    "udate" timestamp
    "created_utc_timestamp" timestamp
    "updated_utc_timestamp" timestamp
    "created_timestamp" timestamp
    "updated_timestamp" timestamp
    "mpp_tracking" text
    "links__bounce_logs" text
    "links__contact_automations" text
    "links__contact_data" text
    "links__contact_goals" text
    "links__contact_lists" text
    "links__contact_logs" text
    "links__contact_tags" text
    "links__contact_deals" text
    "links__deals" text
    "links__field_values" text
    "links__geo_ips" text
    "links__notes" text
    "links__organization" text
    "links__plus_append" text
    "links__tracking_logs" text
    "links__score_values" text
    "links__automation_entry_counts" text
    "id" text [pk, not null]
    "_dlt_load_id" text [not null]
    "_dlt_id" text [unique, not null]
    "ua" text
    "rating_tstamp" text
    "adate" timestamp
    "edate" timestamp
    "created_by" text
    "updated_by" text
    "last_open_date" timestamp
    "last_mpp_open_date" timestamp
    "best_send_hour" text
    "last_click_date" timestamp
    "bounced_date" text
}

Table "lists" [note: 'concept: Event | role: secondary | subtype: list'] {
    "stringid" text
    "userid" text
    "name" text
    "cdate" timestamp
    "p_use_tracking" text
    "p_use_analytics_read" text
    "p_use_analytics_link" text
    "p_use_twitter" text
    "p_use_facebook" text
    "p_embed_image" text
    "p_use_captcha" text
    "send_last_broadcast" text
    "private" text
    "analytics_source" text
    "analytics_ua" text
    "twitter_token" text
    "twitter_token_secret" text
    "carboncopy" text
    "subscription_notify" text
    "unsubscription_notify" text
    "require_name" text
    "get_unsubscribe_reason" text
    "to_name" text
    "optinoptout" text
    "sender_name" text
    "sender_addr1" text
    "sender_addr2" text
    "sender_city" text
    "sender_state" text
    "sender_zip" text
    "sender_country" text
    "sender_phone" text
    "sender_url" text
    "sender_reminder" text
    "fulladdress" text
    "optinmessageid" text
    "optoutconf" text
    "udate" timestamp
    "created_timestamp" timestamp
    "updated_timestamp" timestamp
    "channel" text
    "non_deleted_subscribers" text
    "active_subscribers" text
    "links__contact_goal_lists" text
    "links__user" text
    "links__address_lists" text
    "id" text [pk, not null]
    "user" text
    "_dlt_load_id" text [not null]
    "_dlt_id" text [unique, not null]
}

Table "tags" [note: 'concept: Event | role: secondary | subtype: education_program | excluded_rows: source1, Title, Also_Marketing_Permission, unsubscribed from education, test name field variables, 2024'] {
    "tag_type" text
    "tag" text
    "description" text
    "subscriber_count" text
    "cdate" timestamp
    "created_timestamp" timestamp
    "updated_timestamp" timestamp
    "deleted" text
    "links__contact_goal_tags" text
    "links__template_tags" text
    "id" text [pk, not null]
    "_dlt_load_id" text [not null]
    "_dlt_id" text [unique, not null]
    "created_by" text
    "updated_by" text
}

Table "contact_lists" [note: 'concept: Interaction | role: secondary | links: Person → Event(list)'] {
    "contact" text [pk, not null]
    "list" text [pk, not null]
    "seriesid" text
    "sdate" timestamp
    "status" text
    "responder" text
    "sync" text
    "unsubreason" text
    "first_name" text
    "last_name" text
    "ip4_sub" text
    "sourceid" text
    "ip4_last" text
    "ip4_unsub" text
    "created_timestamp" timestamp
    "updated_timestamp" timestamp
    "created_by" text
    "updated_by" text
    "channel" text
    "links__automation" text
    "links__list" text
    "links__contact" text
    "links__form" text
    "links__autosync_log" text
    "links__campaign" text
    "links__unsubscribe_automation" text
    "links__message" text
    "id" text
    "_dlt_load_id" text [not null]
    "_dlt_id" text [unique, not null]
    "udate" timestamp
    "campaign" text
    "message" text
    "form" text
    "automation" text
}

Table "contact_tags" [note: 'concept: Interaction | role: secondary | links: Person → Event(education_program)'] {
    "contact" text [pk, not null]
    "tag" text [pk, not null]
    "cdate" timestamp
    "created_timestamp" timestamp
    "updated_timestamp" timestamp
    "links__tag" text
    "links__contact" text
    "id" text
    "_dlt_load_id" text [not null]
    "_dlt_id" text [unique, not null]
}

Table "_dlt_version" {
    "version" bigint [not null]
    "engine_version" bigint [not null]
    "inserted_at" timestamp [not null]
    "schema_name" text [not null]
    "version_hash" text [not null]
    "schema" text [not null]
    Note {
        'Created by DLT. Tracks schema updates'
    }
}

Table "_dlt_loads" {
    "load_id" text [not null]
    "schema_name" text
    "status" bigint [not null]
    "inserted_at" timestamp [not null]
    "schema_version_hash" text
    Note {
        'Created by DLT. Tracks completed loads'
    }
}

Table "_dlt_pipeline_state" {
    "version" bigint [not null]
    "engine_version" bigint [not null]
    "pipeline_name" text [not null]
    "state" text [not null]
    "created_at" timestamp [not null]
    "version_hash" text
    "_dlt_load_id" text [not null]
    "_dlt_id" text [unique, not null]
}

Ref {
    "contacts"."_dlt_load_id" > "_dlt_loads"."load_id"
}

Ref {
    "lists"."_dlt_load_id" > "_dlt_loads"."load_id"
}

Ref {
    "tags"."_dlt_load_id" > "_dlt_loads"."load_id"
}

Ref {
    "contact_lists"."_dlt_load_id" > "_dlt_loads"."load_id"
}

Ref {
    "contact_tags"."_dlt_load_id" > "_dlt_loads"."load_id"
}

Ref {
    "_dlt_pipeline_state"."_dlt_load_id" > "_dlt_loads"."load_id"
}

Ref {
    "_dlt_version"."version_hash" < "_dlt_loads"."schema_version_hash"
}

Ref {
    "_dlt_version"."schema_name" <> "_dlt_loads"."schema_name"
}